// -*- mode: jsonc -*-
{
  "position": "bottom",
  "margin": "1 1 1 1",
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "group/expand",
    "custom/pomodoro",
    "battery",
    "network",
    "clock"
  ],
  "hyprland/window": {
    "format": "{initialTitle}",
    "icon": true,
    "rewrite": {
      "(.*)Firefox(.*)": "Firefox",
      "(.*)Spotify(.*)": "Spotify",
      "(.*)GNU Image Manipulation Program(.*)": "GIMP",
      "(.*)kitty(.*)": "Kitty",
      "(.*)Obsidian(.*)": "Obsidian"
    },
    "icon-size": 20,
    "tooltip": false
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5
      ]
    }
  },
  "group/expand": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 600,
      "transition-to-left": true,
      "click-to-reveal": true
    },
    "modules": [
      "custom/expand",
      "cpu",
      "memory",
      "backlight",
      "pulseaudio",
      "custom/colorPicker",
      "custom/endpoint"
    ]
  },
  "cpu": {
    "format": "´ĺ╝  {usage}%",
    "tooltip": true,
    "on-click": "kitty -e btop"
  },
  "memory": {
    "format": "ţ┐ů  {percentage}%",
    "on-click": "kitty -e btop"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 10
  },
  "custom/endpoint": {
    "format": "ţŻŹ",
    "tooltip": false
  },
  "custom/expand": {
    "format": "´üô",
    "tooltip": false
  },
  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "ˇ░Ť│ ",
    "format-disconnected": "ˇ░▓Ť ",
    "tooltip-format-disconnected": "No Connection",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ´üż  {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "{ifname}",
    "format-icons": [
      "<span color=\"#f38ba8\">´çź </span>",
      "<span color=\"#cdd6f4\">´çź </span>",
      "<span color=\"#cdd6f4\">´çź </span>"
    ],
    "on-click": "kitty -e impala"
  },
  "battery": {
    "interval": 1,
    "states": {
      "warning": 15,
      "critical": 5
    },
    "format": "{icon} {capacity}%",
    "format-full": "´âž {capacity}%",
    "format-plugged": "´âž {capacity}%",
    "format-charging": "´âž {capacity}%",
    "format-icons": [
      "´ëä ",
      "´ëâ ",
      "´ëé ",
      "´ëü ",
      "´ëÇ "
    ],
    "format-time": "{H}h {M}m"
  },
  "clock": {
    "format": "{:%H:%M} ",
    "format-alt": "{:%H:%M %e %B %Y}",
    "tooltip": false
  },
  "backlight": {
    "device": "acpi_video1",
    "format": "ţźć {}%",
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "´Őö {volume}%",
    "format-muted": "ţ╗Ę  {volume}%",
    "format-icons": {
      "headphones": "´Çą",
      "default": [
        "´ÇŽ",
        "´Çž ",
        "´ÇĘ "
      ]
    },
    "max-volume": 100,
    "states": {
      "normal": 100,
      "loud": 125
    },
    "tooltip": true,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },
  "custom/colorPicker": {
    "format": "´ç╗ ",
    "tooltip": false,
    "on-click": "hyprpicker --autocopy"
  },
  "custom/pomodoro": {
    "format": "{}",
    "return-type": "json",
    "exec": "waybar-module-pomodoro --work 55 --play '´üő' --pause '´üî' --no-work-icons --persist",
    "on-click": "waybar-module-pomodoro toggle",
    "on-click-right": "waybar-module-pomodoro reset",
    "tooltip": false
  }
}
